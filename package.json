{
  "name": "fcp-mpdp-backend",
  "version": "0.0.0",
  "description": "fcp-mpdp-backend",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "NODE_ENV=development node --env-file-if-exists=.env --watch --watch-path=./src src/index.js",
    "dev:debug": "NODE_ENV=development node --env-file-if-exists=.env --watch --watch-path=./src --inspect src/index.js",
    "docker:build": "docker compose --profile app build",
    "docker:dev": "docker compose --profile app up",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "local": "npm run services:up && npm run dev",
    "services:up": "docker compose up -d --wait",
    "services:down": "docker compose down",
    "start": "NODE_ENV=production node .",
    "test": "cross-env TZ=UTC vitest run --coverage",
    "test:unit": "cross-env TZ=UTC vitest run --coverage --project unit",
    "test:integration": "cross-env TZ=UTC vitest run --coverage --project integration",
    "test:watch": "cross-env TZ=UTC vitest",
    "test:debug": "cross-env TZ=UTC vitest --inspect --no-file-parallelism"
  },
  "author": "Defra DDTS",
  "contributors": [
    "John Watson <john.watson1@defra.gov.uk>",
    "Rana Salem <rana.salem@defra.gov.uk>"
  ],
  "license": "OGL-UK-3.0",
  "dependencies": {
    "@aws-sdk/credential-providers": "3.1039.0",
    "@aws-sdk/rds-signer": "3.1035.0",
    "@defra/cdp-metrics": "0.6.0",
    "@defra/hapi-tracing": "1.22.0",
    "@elastic/ecs-pino-format": "1.5.0",
    "@hapi/hapi": "21.4.0",
    "@hapi/inert": "7.1.1",
    "@hapi/jwt": "3.2.4",
    "@hapi/vision": "7.0.3",
    "@json2csv/node": "7.0.6",
    "convict": "6.2.5",
    "convict-format-with-validator": "6.2.0",
    "csv-parser": "3.0.0",
    "fuse.js": "7.1.0",
    "global-agent": "3.0.0",
    "hapi-pino": "13.0.0",
    "hapi-pulse": "4.0.0",
    "hapi-swagger": "17.2.1",
    "joi": "17.13.4",
    "pg": "8.16.3",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "sequelize": "6.37.8",
    "undici": "7.28.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "12.0.3",
    "@vitest/coverage-v8": "4.1.4",
    "cross-env": "7.0.3",
    "eslint": "9.29.0",
    "neostandard": "0.12.1",
    "testcontainers": "12.0.3",
    "vitest": "4.1.4"
  }
}
