# Copy this file to .env for local development.
# Real environment variables always take precedence over this file.
# .env is gitignored — never commit it.

# Server
PORT=3001
NODE_ENV=development

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_HOST_READ=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_GET_TOKEN_FROM_RDS=false

# Service-to-service authentication (disabled by default)
# SERVICE_AUTH_ENABLED=false
# CDP_JWT_JWKS_URI=
# CDP_JWT_ISSUER=
